# AutoStream Agent – Environment Configuration
# Copy this file to .env and fill in ONE provider key.

# --- LLM Provider (pick one) ---
ANTHROPIC_API_KEY=sk-ant-...      # Claude 3 Haiku (default if set)
# OPENAI_API_KEY=sk-...           # GPT-4o-mini
# GOOGLE_API_KEY=...              # Gemini 1.5 Flash

# --- Optional Overrides ---
# LLM_PROVIDER=anthropic          # Force provider: anthropic | openai | google
# ANTHROPIC_MODEL=claude-3-haiku-20240307
# OPENAI_MODEL=gpt-4o-mini
# GOOGLE_MODEL=gemini-1.5-flash

# --- Debug ---
# DEBUG=1                         # Print intent + lead state after each turn
